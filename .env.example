# ==========================================================================
# 랜선어항 (fish-tank) 환경 변수 예시
# 실제 값은 .env 파일에 넣고 절대 커밋하지 않습니다 (.gitignore 처리됨).
# 이 파일은 필요한 키만 문서화하며, 실제 비밀 값을 담지 않습니다.
# ==========================================================================

# --- 서버: 데이터베이스 --------------------------------------------------
# PostgreSQL 접속 문자열. 개발용은 로컬/서버리스 PostgreSQL 사용.
# server/src/db/pool.js 의 createPoolFromEnv 가 이 값을 읽는다(없으면 기동 실패).
# 예: postgres://user:password@localhost:5432/fishtank
DATABASE_URL=

# --- 서버: 실행 포트 -----------------------------------------------------
PORT=3000

# --- 서버: Microsoft SSO 토큰 검증 --------------------------------------
# Azure AD(Entra) 앱 등록에서 발급받는 값들. 클라이언트 ID = 애플리케이션(클라이언트) ID.
# 서버는 수신한 토큰의 audience(aud)와 issuer(iss)를 아래 기대값과 대조합니다.
# (환경 변수 이름의 TEAMS_ 접두사는 Teams 탭 시절의 흔적으로, 현재는 일반
#  브라우저 MSAL 로그인 토큰 검증에 동일하게 사용됩니다.)

# 이 앱의 애플리케이션(클라이언트) ID. 토큰 audience 검증에 사용.
TEAMS_APP_CLIENT_ID=

# (선택) Application ID URI. audience가 api://<client-id> 형태인 경우 사용.
# 미설정 시 TEAMS_APP_CLIENT_ID 를 audience 기대값으로 사용.
TEAMS_APP_ID_URI=

# Azure AD 테넌트 ID. issuer 검증에 사용.
# issuer 기대값: https://login.microsoftonline.com/<tenant-id>/v2.0
TEAMS_TENANT_ID=

# (선택) JWKS 엔드포인트 URI. 미설정 시 tenant 기준 기본값으로 구성.
# 기본: https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
TEAMS_JWKS_URI=

# --- 서버: Microsoft SSO 검증 필수 값(요약) ------------------------------
# 코드가 실제로 읽는 서버 env: DATABASE_URL, PORT, TEAMS_TENANT_ID(필수),
#   TEAMS_APP_CLIENT_ID(필수), TEAMS_APP_ID_URI(선택), TEAMS_JWKS_URI(선택).
# 실시간 WebSocket URL 은 별도 env 가 없으며 클라이언트가 window.location 에서
#   자동 유도한다(defaultRealtimeUrl). 프록시/역방향 프록시로 /realtime 를 전달하면 된다.

# --- 개발 전용: 인증 우회 (절대 프로덕션 금지) --------------------------
# 실제 Microsoft 로그인 없이 로컬로 앱을 시험하기 위한 우회 스위치.
# 두 값을 모두 켜야 동작하며, 기본은 비활성이다.
#  - 서버: DEV_AUTH_BYPASS=1  → 모든 요청을 고정 개발 신원(dev-user-local)으로 인증.
#          NODE_ENV=production 이면 이 값이 있어도 무시되고 실제 토큰 검증을 사용한다.
#  - 클라: VITE_DEV_AUTH_BYPASS=1 → MSAL 로그인 대신 개발 신원으로 바로 로그인(개발 빌드 한정).
# [경고] 프로덕션 배포 시 두 값 모두 반드시 비워두거나 제거할 것.
DEV_AUTH_BYPASS=
VITE_DEV_AUTH_BYPASS=

# --- 클라이언트: Microsoft SSO 로그인 (MSAL, 빌드 시 주입) ----------------
# 일반 브라우저에서 MSAL.js 리다이렉트 로그인에 사용한다. Vite 빌드 시점에
# 값이 번들에 포함되므로, 배포 빌드 전에 반드시 채워야 한다.
# Azure 앱 등록의 "인증 > 플랫폼: 단일 페이지 애플리케이션(SPA)" 에
# 배포 주소(예: https://fishtank.formationlabs.co.kr)를 리다이렉트 URI 로 등록할 것.

# 앱의 애플리케이션(클라이언트) ID — 서버 TEAMS_APP_CLIENT_ID 와 동일 값.
VITE_TEAMS_APP_CLIENT_ID=

# Azure AD 테넌트 ID — 서버 TEAMS_TENANT_ID 와 동일 값. authority 고정에 사용
# (회사 테넌트 계정만 로그인 허용).
VITE_TEAMS_TENANT_ID=

# (선택) Application ID URI. 미설정 시 api://<client-id> 를 사용.
# 요청 스코프는 <이 값>/access_as_user 로 구성된다.
VITE_TEAMS_APP_ID_URI=

# 백엔드 API 베이스 URL (개발 기본값 예시)
VITE_API_BASE_URL=http://localhost:3000
